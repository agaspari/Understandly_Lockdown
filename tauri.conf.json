{
    "$schema": "https://schema.tauri.app/config/2",
    "identifier": "com.understandly.lockdown",
    "productName": "Understandly Lockdown",
    "version": "0.3.2",
    "build": {
        "frontendDist": "empty",
        "devUrl": "http://localhost:3000"
    },
    "plugins": {
        "deep-link": {
            "desktop": {
                "schemes": [
                    "understandly-lockdown"
                ]
            }
        },
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY2N0I2NzhBQjc0REU5MkMKUldRczZVMjNpbWQ3WmpFMVVKRi91YTZKWnV3OXI3VlJudFBaYkdnR0YwRk5HVGNnK0drenZ2dnAK",
            "endpoints": [
                "https://github.com/agaspari/Understandly_Lockdown/releases/latest/download/latest.json"
            ]
        }
    },
    "bundle": {
        "active": true,
        "createUpdaterArtifacts": true,
        "targets": [
            "nsis",
            "dmg",
            "app"
        ],
        "category": "Education",
        "shortDescription": "Secure Exam Browser",
        "longDescription": "A secure browser for online examinations and quizzes",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "windows": {
            "certificateThumbprint": null,
            "digestAlgorithm": "sha256",
            "timestampUrl": "",
            "wix": {
                "fragmentPaths": [
                    "wix/disable-launch-checkbox.wxs"
                ]
            },
            "nsis": {
                "template": "installer.nsi"
            }
        },
        "macOS": {
            "minimumSystemVersion": "10.15",
            "exceptionDomain": "",
            "frameworks": [],
            "providerShortName": "697M4VQGC9",
            "signingIdentity": "Developer ID Application",
            "entitlements": "Entitlements.plist"
        },
        "linux": {
            "deb": {
                "depends": []
            }
        }
    },
    "app": {
        "security": {
            "csp": {
                "default-src": "'self' https://understandly.com https://*.understandly.com https://understandly-git-development-understandly.vercel.app",
                "connect-src": "ipc: http://ipc.localhost https://understandly.com https://*.understandly.com https://understandly-git-development-understandly.vercel.app wss://understandly.com wss://*.understandly.com",
                "font-src": "'self' data: https://fonts.gstatic.com",
                "img-src": "'self' data: blob: https://understandly.com https://*.understandly.com https://understandly-git-development-understandly.vercel.app",
                "style-src": "'self' 'unsafe-inline' https://fonts.googleapis.com",
                "script-src": "'self' 'wasm-unsafe-eval'"
            },
            "headers": {
                "Cross-Origin-Opener-Policy": "same-origin",
                "Cross-Origin-Embedder-Policy": "require-corp"
            },
            "capabilities": [
                {
                    "identifier": "main-capability",
                    "description": "Capability for the main window with core permissions",
                    "windows": [
                        "main"
                    ],
                    "permissions": [
                        "core:default"
                    ]
                },
                {
                    "identifier": "loading-recovery-capability",
                    "description": "Allows the local loading recovery window to close before a quiz starts",
                    "windows": [
                        "loading-recovery"
                    ],
                    "permissions": [
                        "allow-close-during-loading"
                    ]
                },
                {
                    "identifier": "hosted-exam-capability",
                    "description": "Narrow command access for the configured hosted exam application",
                    "local": false,
                    "remote": {
                        "urls": [
                            "http://localhost:3000",
                            "https://understandly.com",
                            "https://www.understandly.com",
                            "https://understandly-git-development-understandly.vercel.app"
                        ]
                    },
                    "windows": [
                        "main"
                    ],
                    "permissions": [
                        "allow-close-app",
                        "allow-close-lockdown",
                        "allow-mark-quiz-ready",
                        "allow-check-multiple-monitors",
                        "allow-get-monitor-count"
                    ]
                }
            ]
        }
    }
}